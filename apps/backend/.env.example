# Local Postgres connection string (you said Postgres is already installed locally, no Docker)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/splitcheck

PORT=4000

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-random-secret

# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# (an OAuth client ID of type "Web application" works for verifying ID tokens
# from both the mobile app and the web app)
GOOGLE_CLIENT_ID=

# Where uploaded receipt photos are stored on disk
UPLOADS_DIR=./uploads

# https://console.anthropic.com/ -- used to extract line items from receipt photos
ANTHROPIC_API_KEY=

# Comma-separated list of allowed origins for the web app, or * for dev
CORS_ORIGIN=*

NODE_ENV=development

# Create a project at https://sentry.io and paste its DSN here. Leave blank
# to disable error/perf monitoring (the SDK no-ops without a DSN).
SENTRY_DSN=
