VITE_API_URL=http://localhost:4000

# Same Google OAuth "Web application" client ID used by apps/backend's
# GOOGLE_CLIENT_ID and apps/mobile's EXPO_PUBLIC_GOOGLE_CLIENT_ID.
# Create it at https://console.cloud.google.com/apis/credentials and add
# this dev server's origin (e.g. http://localhost:5173) to "Authorized
# JavaScript origins".
VITE_GOOGLE_CLIENT_ID=

# Create a project at https://sentry.io (platform: React) and paste its
# DSN here. Leave blank to disable error/perf monitoring.
VITE_SENTRY_DSN=
