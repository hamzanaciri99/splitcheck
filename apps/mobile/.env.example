# Backend API base URL. For a physical device, use your machine's LAN IP
# (http://localhost only works in the iOS simulator / Android emulator with
# adb reverse, or Expo web).
EXPO_PUBLIC_API_URL=http://localhost:4000

# Google OAuth "Web application" client ID (same one used by apps/backend's
# GOOGLE_CLIENT_ID, and by apps/web). Create it at
# https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
